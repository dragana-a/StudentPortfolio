<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Software Development student portfolio showcasing projects, skills, experience, resume, and contact information." />
    <meta name="keywords" content="software developer, student developer, ASP.NET Core, portfolio, C#, web development" />
    <meta name="author" content="Dragana Acamovic" />
    <meta property="og:title" content="Dragana Acamovic - Software Developer Portfolio" />
    <meta property="og:description" content="Portfolio for internships, co-op roles, and junior software development opportunities." />
    <title>@ViewData["Title"] - Dragana Acamovic's Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
</head>
<body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <nav class="navbar navbar-expand-lg fixed-top glass-nav" aria-label="Main navigation">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">&lt;Dragana Acamovic/&gt;</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="About" asp-action="Index">About</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Projects" asp-action="Index">Projects</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Skills" asp-action="Index">Skills</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Experience" asp-action="Index">Experience</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Resume" asp-action="Index">Resume</a></li>
                    <li class="nav-item"><a class="btn btn-primary rounded-pill px-3" asp-controller="Contact" asp-action="Index">Contact</a></li>
                    <li class="nav-item"><button id="themeToggle" class="btn btn-outline-secondary rounded-pill ms-lg-2" type="button" aria-label="Toggle dark mode"><i class="bi bi-moon-stars"></i></button></li>
                </ul>
            </div>
        </div>
    </nav>
    <main id="main-content" class="page-shell">
        @RenderBody()
    </main>
    <footer class="footer py-5 mt-5">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-3">
            <div>
                <strong>Dragana Acamovic</strong>
                <p class="mb-0 text-muted-custom">Software Development Student | Open to internships, co-op, and junior roles.</p>
            </div>
            <div class="social-links">
                <a href="https://github.com/dragana-a" aria-label="GitHub"><i class="bi bi-github"></i></a>
                <a href="https://linkedin.com/in/dragana-acamovic-900337270" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                <a href="mailto:acamovic.dragana@gmail.com" aria-label="Email"><i class="bi bi-envelope"></i></a>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
