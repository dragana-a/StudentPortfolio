@model ProjectsViewModel
@{
    ViewData["Title"] = "Projects";
}
<section class="sub-hero"><div class="container"><span class="eyebrow">Projects</span><h1>Searchable project gallery.</h1><p>Explore academic, client, data, and full-stack projects.</p></div></section>
<section class="section-pad"><div class="container">
<div class="filter-panel glass-card mb-4"><div class="row g-3 align-items-center"><div class="col-md-6"><label for="projectSearch" class="form-label">Search projects</label><input id="projectSearch" class="form-control form-control-lg" placeholder="Search by title or tech stack..." /></div><div class="col-md-6"><label for="categoryFilter" class="form-label">Filter by category</label><select id="categoryFilter" class="form-select form-select-lg"><option value="all">All categories</option>@foreach (var category in Model.Categories){<option value="@category.ToLowerInvariant()">@category</option>}</select></div></div></div>
<div class="project-grid" id="projectGrid">@foreach (var project in Model.Projects){<partial name="_ProjectCard" model="project" />}</div>
<p id="noProjects" class="text-center text-muted-custom mt-4 d-none">No projects match your search.</p>
</div></section>
