@model List<ExperienceItem>
@{
    ViewData["Title"] = "Experience";
}
<section class="sub-hero"><div class="container"><span class="eyebrow">Experience</span><h1>Growth timeline.</h1><p>Internships, education, client work, leadership, awards, and certifications.</p></div></section>
<section class="section-pad"><div class="container"><div class="timeline">
@foreach (var item in Model)
{
    <article class="timeline-item"><div class="timeline-dot"></div><div class="content-card"><span class="badge text-bg-primary mb-2">@item.Type</span><h2 class="h4">@item.Title</h2><p class="fw-semibold mb-1">@item.Organization</p><p class="text-muted-custom">@item.DateRange</p><p>@item.Description</p><ul>@foreach(var h in item.Highlights){<li>@h</li>}</ul></div></article>
}
</div></div></section>
